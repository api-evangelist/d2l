    "GradeValue": {
      "@id": "d2l:GradeValue",
      "@type": "@id"
    },
    "PointsNumerator": "d2l:pointsNumerator",
    "PointsDenominator": "d2l:pointsDenominator",
    "DisplayedGrade": "d2l:displayedGrade",
    "GradeObjectIdentifier": "d2l:gradeObjectIdentifier",

    "Quiz": {
      "@id": "d2l:Quiz",
      "@type": "@id"
    },
    "QuizId": "d2l:quizId",
    "AllowHints": "d2l:allowHints",
    "DisableRightClick": "d2l:disableRightClick",
    "TimeLimit": "d2l:timeLimit",

    "Discussion": {
      "@id": "d2l:Discussion",
      "@type": "@id"
    },
    "Forum": {
      "@id": "d2l:Forum",
      "@type": "@id"
    },
    "Topic": {
      "@id": "d2l:Topic",
      "@type": "@id"
    },

    "ContentObject": {
      "@id": "d2l:ContentObject",
      "@type": "@id"
    },
    "ContentModuleId": "d2l:contentModuleId",
    "ContentTopicId": "d2l:contentTopicId",

    "Dropbox": {
      "@id": "d2l:Dropbox",
      "@type": "@id"
    },
    "DropboxId": "d2l:dropboxId",
