{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "d2l": "https://www.d2l.com/vocab/",
    "valence": "https://docs.valence.desire2learn.com/vocab/",

    "LearningManagementSystem": "schema:LearningResource",
    "Course": "schema:Course",
    "CourseInstance": "schema:CourseInstance",
    "Person": "schema:Person",
    "Organization": "schema:Organization",
    "EducationalOrganization": "schema:EducationalOrganization",

    "OrganizationalUnit": {
      "@id": "d2l:OrganizationalUnit",
      "@type": "@id"
    },
    "OrgUnitId": "d2l:orgUnitId",
    "OrgUnitType": "d2l:orgUnitType",
    "OrgUnitCode": "d2l:orgUnitCode",
    "IsActive": "d2l:isActive",
    "Path": "d2l:path",

    "Enrollment": {
      "@id": "d2l:Enrollment",
      "@type": "@id"
    },
    "EnrollmentStatus": "d2l:enrollmentStatus",
    "RoleId": "d2l:roleId",
    "AccessExpires": "d2l:accessExpires",
    "LastAccessed": "d2l:lastAccessed",

    "User": {
      "@id": "d2l:User",
      "@type": "@id"
    },
    "UserId": "d2l:userId",
    "Username": "d2l:username",
    "ExternalEmail": "d2l:externalEmail",
    "FirstName": "schema:givenName",
    "LastName": "schema:familyName",
    "IsActive": "d2l:isActive",
    "OrgDefinedId": "d2l:orgDefinedId",

    "GradeObject": {
      "@id": "d2l:GradeObject",
