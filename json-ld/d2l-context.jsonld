      "@id": "d2l:Submission",
      "@type": "@id"
    },

    "ePortfolioArtifact": {
      "@id": "d2l:ePortfolioArtifact",
      "@type": "@id"
    },
    "Reflection": {
      "@id": "d2l:Reflection",
      "@type": "@id"
    },
    "Presentation": {
      "@id": "d2l:Presentation",
